{
  "manifest_version": 3,
  "name": "GitHub Comment Inserter",
  "version": "1.0.0",
  "description": "Insert predefined text into GitHub comment boxes from the right-click menu.",
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
